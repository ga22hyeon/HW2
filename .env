# Server Config
APP_NAME="Face Age Prediction API"
APP_VERSION="1.0.0"
DEBUG=True
HOST=0.0.0.0
PORT=8000

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# Model Config
FACE_DETECTOR_BACKEND=opencv
AGE_MODEL_ACTIONS=age,gender,emotion

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
